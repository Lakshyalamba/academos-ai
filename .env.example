# Server-side Gemini configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

# Optional Google AI aliases supported by the backend
GOOGLE_API_KEY=
GOOGLE_MODEL=

# Optional client-side API override
# Leave blank for same-origin Next.js deployments.
NEXT_PUBLIC_API_BASE_URL=

# Optional backend CORS configuration when the browser app calls a separate API origin.
# Comma-separated list of allowed frontend origins.
ALLOWED_FRONTEND_ORIGINS=
# Legacy single-origin alias still supported.
CORS_ALLOWED_ORIGIN=

# Optional Newton MCP runtime configuration
NEWTON_CODEX_SERVER_NAME=newton
NEWTON_MCP_PACKAGE=@newtonschool/newton-mcp@latest
NEWTON_NPX_COMMAND=npx
CODEX_COMMAND=codex
# Optional: force demo fallback mode even when Newton MCP is configured.
ACADEMOS_FORCE_DEMO_MODE=

# Optional Supabase persistence
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ACADEMIC_SNAPSHOTS_TABLE=academic_snapshots
